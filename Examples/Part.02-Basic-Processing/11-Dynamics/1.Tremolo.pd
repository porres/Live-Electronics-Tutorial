#X obj 870 450 nbx 5 14 -1e+37 1e+37 0 0 empty empty empty 0 -8 0 10 #dcdcdc #000000 #000000 0 256;
#X obj 873 427 hsl 128 15 0 1 0 0 empty empty empty -2 -8 0 10 #dcdcdc #000000 #000000 0 1;
#X text 885 393 Hz;
#X obj 643 292 rescale~ 0 1;
#X obj 683 212 expr 1 - $f1;
#X floatatom 683 238 9 0 0 0 - - - 0;
