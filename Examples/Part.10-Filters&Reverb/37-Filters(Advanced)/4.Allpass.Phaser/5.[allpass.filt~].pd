#N canvas 596 41 478 494 12;
#X declare -path else;
#X obj 105 290 noise~;
#X obj 175 278 nbx 5 14 10 10000 1 0 empty empty empty 0 -8 0 10 #dcdcdc #000000 #000000 0 256;
#X obj 228 310 nbx 5 14 1 100 1 0 empty empty empty 0 -8 0 10 #dcdcdc #000000 #000000 0 256;
#X obj 105 419 out~;
#X obj 105 378 +~;
#X obj 283 19 declare -path else;
#X text 286 305 resonance;
#X text 233 269 resonant/center frequency, f 15;
#X obj 123 342 allpass.filt~ 8 500 0.5;
#X text 55 50 The [allpass.filt~] object from the ELSE library is an abstraction that stacks many [allpass.2nd~] objects in cascade \, so you have multiple 2nd order sections. This means you need to set the order as a multiple of 2! The maximum order of this object is 128 (64 second order sections)!, f 52;
#X text 55 146 As we've seen \, at each 2nd order section \, the filter distorts the phase one full cycle. If we sum the input to the filtered signal \, we can hear the phase cancellation at each frequency point there's a phase opposition. In this example we have an 8th order filter \, this means it has 4 phase cancellation points. So it's like having 4 bandstop filters., f 52;
#X text 251 388 There's also a right inlet for feedback \, but that's just for implementing phasers., f 26;
#X connect 0 0 4 0;
#X connect 0 0 8 0;
#X connect 1 0 8 1;
#X connect 2 0 8 2;
#X connect 4 0 3 0;
#X connect 8 0 4 1;
