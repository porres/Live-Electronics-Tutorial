#N canvas 236 25 1001 636 12;
#X declare -path else;
#X obj 189 320 osc~;
#X obj 189 260 sig~ 440;
#X obj 608 296 noise~;
#X obj 684 284 hsl 128 15 250 1000 1 0 empty cutoff empty -2 -8 0 10 #dcdcdc #000000 #000000 0 1;
#X floatatom 681 310 6 0 0 0 - - - 0;
#X obj 189 355 out~;
