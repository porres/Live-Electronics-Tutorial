#X obj 650 168 initmess \; \$0-p1 1 0.15 0.7 \; \$0-p2 1.99 0.1 1 \; \$0-p3 3.01 0.85 0.5 \; \$0-p4 4.03 0 1 \; \$0-p5 4.95 0.325 0.4 \; \$0-p6 6.05 0.9 0.7 \; \$0-p7 7.07 0.7 0.6 \; \$0-p8 7.93 0.25 0.8 \; \$0-fund 110;
